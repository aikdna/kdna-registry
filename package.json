{
  "name": "@aikdna/kdna-registry",
  "version": "3.1.0",
  "private": true,
  "description": "KDNA public registry metadata and validation gates.",
  "type": "commonjs",
  "scripts": {
    "validate": "node scripts/validate-registry.js",
    "validate:remote": "node scripts/validate-registry.js --remote",
    "check:quality": "node scripts/check-quality-badges.js",
